# =================================================================
# 0. SYSTEM MODE
# =================================================================
# Set to true to disable automatic mock login in development mode
VITE_DISABLE_DEV_AUTH=true
# Comma-separated list of allowed hosts for the Vite dev server
VITE_ALLOWED_HOSTS=verdant.yourdomain.com

# =================================================================
# 1. DATABASE CONFIGURATION (PostgreSQL 16)
# =================================================================
DB_USER=verdant_root
DB_NAME=verdant_botanical
# IMPORTANT: Change this password to a secure value before deploying
DB_PASSWORD=random-alpha-numeric-84-charactor-long-key

# ================================================================
# 2. GOOGLE CLIENT ID
# ================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# =================================================================
# 3. REMOTE SERVER CONFIGURATION (For distributed setups)
# =================================================================
# Path to your server (e.g. https://your-app-id.a.run.app)
VITE_API_URL=https://your-server-url.com

# =================================================================
# 3. SECURITY PROTOCOLS (ALE / AES-256-GCM)
# =================================================================
# This key is used to encrypt plant data in the browser before it hits the DB.
# It must be exactly 50 characters. DO NOT SHARE.
MASTER_KEY=50charactor-random-key

# =================================================================
# 4. PRIMARY AI ENGINE (Google Gemini)
# =================================================================
GEMINI_API_KEY=your-gemini-api-key

# =================================================================
# 5. BOTANICAL ARCHIVE API CLUSTER (Extracted from Source)
# =================================================================
PLANTNET_API_KEY=your-plantnet-api-key
TREFLE_TOKEN=your-trefle-api-token
OPB_CLIENT_ID=your-opb-client-id
OPB_CLIENT_SECRET=your-opb-client-secret
PERENUAL_API_KEY=your-perenual-api-key

# =================================================================
# 6. SEARCH & DISCOVERY ENGINE (Serper.dev)
# =================================================================
SERPER_API_KEY=your-serper-api-key

# =================================================================
# 7. ROOT OWNER
# =================================================================
VITE_ROOT_OWNER_EMAIL=your_username@gmail.com

# =================================================================
# 8. CLOUDFLARE NETWORK TUNNEL TOKENS
# =================================================================
# These allow your Proxmox LXC to talk to the public web via verdant.yknet.org
CF_UNIFIED_TOKEN=your-cloudflare-tunnel-token